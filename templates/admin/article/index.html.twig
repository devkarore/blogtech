{% extends 'base.html.twig' %}

{% block title %}Article index{% endblock %}

{% block body %}
    <h1>Article index</h1>

    <table class="table">
        <thead>
            <tr>
                {# <th>Id</th> #}
                <th>Titre</th>
                <th>Auteur</th>
                {# <th>Slug</th> #}
                <th>Statut</th>
                <th>Date de création</th>
                {# <th>UpdatedAt</th> #}
                {# <th>Content</th> #}
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for article in articles %}
            <tr>
                {# <td>{{ article.id }}</td>! #}
                <td>{{ article.title }}</td>
                <td>{{ article.author.username }}</td>
                <td>{{ article.status.value }}</td>
                {# <td>{{ article.slug }}</td> #}
                <td>{{ article.createdAt ? article.createdAt|date('d/m/Y') : '' }}</td>
                {# <td>{{ article.updatedAt ? article.updatedAt|date('Y-m-d H:i:s') : '' }}</td> #}
                {# <td>{{ article.content }}</td> #}
                <td>
                                    
                    {{ include('admin/article/_delete_form.html.twig') }}
                
                    {# <a href="{{ path('app_admin_article_show', {'id': article.id}) }}">show</a> #}
                    {# <a href="{{ path('app_admin_article_edit', {'id': article.id}) }}">edit</a> #}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_admin_article_new') }}">Créer un article</a>
    
{% endblock %}
